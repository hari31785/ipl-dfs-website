# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ipl_dfs_db"

# Score Provider API Configuration
# Set to 'true' to enable automatic score fetching from external API
ENABLE_SCORE_API=false

# Your score provider API key
# Get this from your score provider dashboard
SCORE_API_KEY=your_api_key_here

# Score provider base URL
# Default: https://api.cricketdata.org/v1
# Change this to match your actual provider's API endpoint
SCORE_API_BASE_URL=https://api.cricketdata.org/v1

# Example configurations for popular cricket data providers:
# 
# CricAPI:
# SCORE_API_BASE_URL=https://api.cricapi.com/v1
# SCORE_API_KEY=your_cricapi_key
#
# Cricketdata.org:
# SCORE_API_BASE_URL=https://api.cricketdata.org/v1
# SCORE_API_KEY=your_cricketdata_key
#
# RapidAPI Cricket Live:
# SCORE_API_BASE_URL=https://cricket-live-data.p.rapidapi.com
# SCORE_API_KEY=your_rapidapi_key
