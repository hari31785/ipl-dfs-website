{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 30
    },
    "app/api/user/*.ts": {
      "maxDuration": 10
    },
    "app/api/messages/*.ts": {
      "maxDuration": 10
    },
    "app/api/messages/**/*.ts": {
      "maxDuration": 10
    },
    "app/api/tournaments/route.ts": {
      "maxDuration": 10
    },
    "app/api/games/route.ts": {
      "maxDuration": 10
    }
  },
  "env": {
    "NEXTAUTH_URL": "https://ipl-dfs-website.vercel.app"
  },
  "crons": [
    {
      "path": "/api/cron/auto-fetch-scores",
      "schedule": "*/2 11-19 * * *"
    }
  ]
}