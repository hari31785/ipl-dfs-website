{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/auto-fetch-scores",
      "schedule": "*/10 11-19 * * *"
    }
  ],
  "env": {
    "NEXTAUTH_URL": "https://ipl-dfs-website.vercel.app"
  }
}